# API
SCRIPTUBE_BASE_URL=https://scriptube.me
SCRIPTUBE_API_KEY=your_api_key_here

# UI credentials
SCRIPTUBE_EMAIL=your_email@example.com
SCRIPTUBE_PASSWORD=your_password_here

# Browser (UI tests)
# SCRIPTUBE_BROWSER=chromium
# BROWSER_HEADLESS=true
# BROWSER_SLOW_MO=500
# BROWSER_VIEWPORT_WIDTH=1280
# BROWSER_VIEWPORT_HEIGHT=900

# Webhooks
WEBHOOK_RECEIVER_URL=https://your-receiver.example.com/hook
# WEBHOOK_RECEIVER_PORT=5099
# NGROK_API_PORT=4040

# Timeout / poll tuning 
# --- HTTP & polling ---
# Timeouts__RequestSeconds=30
# Timeouts__PollIntervalSeconds=3
# Timeouts__PollTimeoutSeconds=120
# --- UI ---
# Timeouts__PlaywrightNavigationMs=30000
# Timeouts__PlaywrightActionMs=10000
# --- Webhooks ---
# Timeouts__WebhookDispatchWaitSeconds=10
# Timeouts__WebhookDeliveryTimeoutSeconds=30
# Timeouts__NgrokApiTimeoutSeconds=5
# --- Batch cancel ---
# Timeouts__CancelSettleSeconds=2
# --- Auth rate-limit cooldown ---
# Timeouts__AuthCooldownMs=3000

# --- Retry policy ---
# Retry__Count=3
# Retry__DelaySeconds=2
