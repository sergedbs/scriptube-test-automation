# API
SCRIPTUBE_BASE_URL=https://scriptube.me
SCRIPTUBE_API_KEY=your_api_key_here

# UI credentials
SCRIPTUBE_EMAIL=your_email@example.com
SCRIPTUBE_PASSWORD=your_password_here

# Webhooks
WEBHOOK_RECEIVER_URL=https://your-receiver.example.com/hook

# Tuning parameters
